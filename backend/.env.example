# Server
PORT=4000
NODE_ENV=development

# Database (Supabase Postgres connection string)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres?schema=public"

# JWT
JWT_SECRET="replace-with-a-long-random-secret-string"
JWT_EXPIRES_IN="8h"

# CORS
CLIENT_ORIGIN="http://localhost:5173"

# Seed admin (used only by prisma/seed.ts)
SEED_MANAGER_EMAIL="manager@queueflow.com"
SEED_MANAGER_PASSWORD="ChangeMe123!"
SEED_MANAGER_NAME="Queue Manager"

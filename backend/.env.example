# Server
PORT=4000
NODE_ENV=development

# Database (Supabase Postgres)
# DATABASE_URL: Transaction-mode pooler (port 6543) - used for normal app queries
DATABASE_URL="postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: Session-mode pooler (port 5432) - used only for migrations
DIRECT_URL="postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="replace-with-a-long-random-secret-string"
JWT_EXPIRES_IN="8h"

# CORS
CLIENT_ORIGIN="http://localhost:5173"

# Seed admin (used only by prisma/seed.ts)
SEED_MANAGER_EMAIL="manager@queueflow.com"
SEED_MANAGER_PASSWORD="ChangeMe123!"
SEED_MANAGER_NAME="Queue Manager"
